rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Función para verificar que el usuario está autenticado
    function isAuthenticated() {
      return request.auth != null;
    }

    // Función para verificar que el documento pertenece al usuario (Tenant Isolation)
    function belongsToUser(userId) {
      return request.auth.uid == userId;
    }

    // Regla para la colección de Clientes
    match /clients/{clientId} {
      allow read, write: if isAuthenticated() && belongsToUser(resource.data.tenantId || request.resource.data.tenantId);
    }

    // Regla para la colección de Productos/Inventario
    match /products/{productId} {
      allow read, write: if isAuthenticated() && belongsToUser(resource.data.tenantId || request.resource.data.tenantId);
    }

    // Regla para la colección de Facturas
    match /invoices/{invoiceId} {
      allow read, write: if isAuthenticated() && belongsToUser(resource.data.tenantId || request.resource.data.tenantId);
    }

    // Regla para la configuración del Negocio (Sellos, Llaves)
    match /tenants/{tenantId} {
      allow read, write: if isAuthenticated() && belongsToUser(tenantId);
    }
  }
}
